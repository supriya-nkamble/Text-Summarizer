# Model artifacts location (populated after running main.py)
MODEL_PATH=artifacts/model_trainer/pegasus-model
TOKENIZER_PATH=artifacts/model_trainer/tokenizer

# Training configuration (override params.yaml)
NUM_TRAIN_EPOCHS=1
PER_DEVICE_TRAIN_BATCH_SIZE=1

# Hugging Face cache (optional — reduces repeated downloads)
HF_HOME=~/.cache/huggingface
